{
	"appId": "com.alyssa.polaris",
	"appName": "Polaris",
	"webDir": "dist",
	"server": {
		"iosScheme": "http",
		"hostname": "localhost"
	},
	"plugins": {
		"CapacitorHttp": {
			"enabled": false
		},
		"Keyboard": {
			"resize": "none"
		},
		"LocalNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"banner",
				"list"
			]
		}
	}
}
